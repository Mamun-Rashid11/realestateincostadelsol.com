---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AreasGrid from '../../components/AreasGrid.astro';
import LeadForm from '../../components/LeadForm.astro';
---
<BaseLayout
  title="Costa del Sol Property for Sale | Real Estate in Costa del Sol"
  description="Browse property for sale across the Costa del Sol. Villas, apartments and new developments in Marbella, Estepona, Fuengirola, Nerja and beyond."
  canonical="https://realestateincostadelsol.com/costa-del-sol/"
  ogImage="/og/costa-del-sol.jpg"
>
  <div class="page-hero">
    <div class="container">
      <span class="eyebrow" data-animate style="--anim-delay:100ms">Costa del Sol</span>
      <h1 data-animate style="--anim-delay:220ms">Costa del Sol Property for Sale</h1>
      <p data-animate style="--anim-delay:340ms">Spain's most popular coastline for foreign buyers. 300+ days of sunshine, world-class golf, and property at every price point.</p>
    </div>
  </div>

  <section class="area-intro">
    <div class="container area-intro__inner">
      <div class="area-intro__text">
        <h2 data-animate>Why Buy in Costa del Sol?</h2>
        <p>The Costa del Sol stretches 150km along Andalusia's Mediterranean coast, from Gibraltar in the west to Almería in the east. It's the most established foreign buyer market in Spain — and for good reason.</p>
        <p>UK buyers are the largest group of foreign property owners here, drawn by easy flight connections (2–3 hours from most UK airports), a large English-speaking expat community, and reliable sunshine from March to November.</p>

        <div class="facts-box" data-animate>
          <h3>Key Facts — Costa del Sol Property Market 2026</h3>
          <ul>
            <li>Average price: €2,450/m² (range: €1,200–€8,000+/m²)</li>
            <li>Most popular areas: Marbella, Estepona, Benalmádena, Fuengirola</li>
            <li>Typical buyer nationality: UK (28%), German (18%), Swedish (12%)</li>
            <li>Rental yields: 4–7% gross in the right locations</li>
            <li>Non-resident buying process: 6–12 weeks from offer to completion</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <AreasGrid />
  <LeadForm area="Costa del Sol" heading="Looking for Property in Costa del Sol?" />
</BaseLayout>

<style>
.page-hero { background: var(--green); padding: 80px 0; }
.page-hero .eyebrow { color: var(--accent); display: block; margin-bottom: 12px; }
.page-hero h1 { color: var(--white); font-size: clamp(2rem, 4.5vw, 3.2rem); margin-bottom: 16px; }
.page-hero p { color: rgba(255,255,255,0.8); font-size: 16px; max-width: 600px; line-height: 1.7; }
.area-intro { padding: 64px 0; background: var(--white); }
.area-intro__inner { max-width: 800px; }
.area-intro__text h2 { margin-bottom: 16px; }
.area-intro__text p { color: var(--text-muted); margin-bottom: 16px; line-height: 1.8; }
.facts-box {
  background: var(--green-lt);
  border: 1px solid var(--border);
  border-left: 4px solid var(--accent);
  border-radius: 8px;
  padding: 24px;
  margin-top: 24px;
}
.facts-box h3 { font-size: 15px; margin-bottom: 12px; color: var(--text); }
.facts-box ul { margin-left: 20px; }
.facts-box li { font-size: 14px; color: var(--text-muted); margin-bottom: 6px; }
</style>
