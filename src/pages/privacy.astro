---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Privacy Policy | Real Estate in Costa del Sol"
  description="Privacy policy for realestateincostadelsol.com — how we collect, use and protect your data."
  canonical="https://realestateincostadelsol.com/privacy/"
>
  <div class="page-hero">
    <div class="container">
      <span class="eyebrow" data-animate style="--anim-delay:100ms">Legal</span>
      <h1 data-animate style="--anim-delay:220ms">Privacy Policy</h1>
    </div>
  </div>
  <section class="privacy-content">
    <div class="container privacy-content__inner">
      <p><strong>Last updated:</strong> June 2026</p>

      <h2 data-animate>Data We Collect</h2>
      <p>When you submit an enquiry form on this site, we collect your name, email address, and the details you provide about your property search. This information is processed by <a href="https://web3forms.com" target="_blank" rel="noopener">Web3Forms</a> and sent to us via email.</p>

      <h2 data-animate>How We Use Your Data</h2>
      <p>Your enquiry is forwarded to our partner agency Casa Espanha (casaespanha.com) so they can respond to your property search request. We do not sell or share your data with any other third parties.</p>

      <h2 data-animate>Cookies</h2>
      <p>This site may use analytics cookies (Google Analytics or Plausible Analytics) to understand traffic patterns. These cookies do not identify you personally. You can disable cookies in your browser settings.</p>

      <h2 data-animate>Your Rights</h2>
      <p>Under GDPR, you have the right to access, rectify or delete personal data we hold about you. To exercise these rights, email us at: <a href="mailto:hridoy11.rk@gmail.com">hridoy11.rk@gmail.com</a></p>

      <h2 data-animate>Contact</h2>
      <p>For privacy-related queries: <a href="mailto:hridoy11.rk@gmail.com">hridoy11.rk@gmail.com</a></p>
    </div>
  </section>
</BaseLayout>

<style>
.page-hero { background: var(--green); padding: 64px 0; }
.page-hero .eyebrow { color: var(--accent); display: block; margin-bottom: 12px; }
.page-hero h1 { color: var(--white); font-size: clamp(1.8rem, 4vw, 2.8rem); }
.privacy-content { padding: 64px 0; }
.privacy-content__inner { max-width: 760px; }
.privacy-content__inner h2 { margin-top: 36px; margin-bottom: 12px; font-size: 1.3rem; }
.privacy-content__inner h2:first-of-type { margin-top: 24px; }
.privacy-content__inner p { color: var(--text-muted); margin-bottom: 12px; line-height: 1.8; }
.privacy-content__inner a { color: var(--green); text-decoration: underline; }
</style>
