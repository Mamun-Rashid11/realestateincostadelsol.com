---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/LeadForm.astro';
---
<BaseLayout
  title="Costa Cálida Property for Sale | Murcia Region, Spain"
  description="Buy property on the Costa Cálida — Murcia's warm coast. Mar Menor, Mazarrón and Cartagena. Affordable Spanish property with year-round sunshine."
  canonical="https://realestateincostadelsol.com/costa-calida/"
>
  <div class="page-hero">
    <div class="container">
      <span class="eyebrow" data-animate style="--anim-delay:100ms">Costa Cálida</span>
      <h1 data-animate style="--anim-delay:220ms">Costa Cálida Property for Sale</h1>
      <p data-animate style="--anim-delay:340ms">Murcia's warm coast — home to the Mar Menor lagoon, pine-fringed beaches, and some of Spain's most affordable coastal property.</p>
    </div>
  </div>

  <section class="area-content">
    <div class="container area-content__inner">
      <div class="facts-box" data-animate>
        <h3>Costa Cálida Quick Facts 2026</h3>
        <ul>
          <li>Average price: €1,100/m² (range: €700–€2,500/m²)</li>
          <li>Key areas: Mar Menor, Mazarrón, Cartagena, Los Alcázares</li>
          <li>Airport: Murcia Region International (RMU) — Ryanair/easyJet from UK</li>
          <li>Good value: often 40–50% cheaper per m² than Costa del Sol</li>
        </ul>
      </div>

      <h2 data-animate>Why Consider Costa Cálida?</h2>
      <p>The Costa Cálida is one of Spain's most underrated coastal regions. The Mar Menor — Europe's largest saltwater lagoon — offers calm, warm waters ideal for families. The region gets over 300 days of sunshine per year and has seen significant infrastructure investment.</p>
      <p>For budget-conscious buyers or those seeking second homes with low running costs, Costa Cálida offers remarkable value.</p>

      <div class="internal-links" data-animate>
        <h3>Related Pages</h3>
        <ul>
          <li><a href="/">← Homepage</a></li>
          <li><a href="/costa-del-sol/">Costa del Sol Properties</a></li>
          <li><a href="/costa-blanca/">Costa Blanca Properties</a></li>
        </ul>
      </div>
    </div>
  </section>

  <LeadForm area="Costa Cálida" heading="Interested in Costa Cálida Property?" />
</BaseLayout>

<style>
.page-hero { background: var(--green); padding: 80px 0; }
.page-hero .eyebrow { color: var(--accent); display: block; margin-bottom: 12px; }
.page-hero h1 { color: var(--white); font-size: clamp(2rem, 4.5vw, 3.2rem); margin-bottom: 16px; }
.page-hero p { color: rgba(255,255,255,0.8); font-size: 16px; max-width: 600px; line-height: 1.7; }
.area-content { padding: 64px 0; background: var(--white); }
.area-content__inner { max-width: 800px; }
.area-content__inner h2 { margin-top: 40px; margin-bottom: 14px; }
.area-content__inner h2:first-of-type { margin-top: 32px; }
.area-content__inner p { color: var(--text-muted); margin-bottom: 14px; line-height: 1.8; }
.facts-box { background: var(--green-lt); border: 1px solid var(--border); border-left: 4px solid var(--accent); border-radius: 8px; padding: 24px; margin-bottom: 32px; }
.facts-box h3 { font-size: 15px; margin-bottom: 12px; font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; }
.facts-box ul { margin-left: 20px; }
.facts-box li { font-size: 14px; color: var(--text-muted); margin-bottom: 6px; }
.internal-links { background: var(--off-white); border-radius: 8px; padding: 20px 24px; margin-top: 40px; }
.internal-links h3 { font-size: 14px; font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; margin-bottom: 10px; }
.internal-links ul { margin-left: 0; list-style: none; }
.internal-links li { margin-bottom: 6px; }
.internal-links a { color: var(--green); font-size: 14px; text-decoration: underline; }
</style>
