---
import { getCollection } from 'astro:content';
import BlogCard from './BlogCard.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

const [featured, ...rest] = posts;
---
{posts.length > 0 && (
  <section class="blog-section">
    <div class="container">
      <div class="blog-section__header">
        <span class="eyebrow" data-animate>Buyer Guides & Market Insights</span>
        <h2 class="section-h2" data-animate style="--anim-delay:80ms">Latest from the Blog</h2>
        <p data-animate style="--anim-delay:160ms">In-depth guides for UK and US buyers navigating the Spanish property market.</p>
      </div>
      <div class="blog-layout" data-stagger data-stagger-base="100" data-stagger-step="100">
        {featured && (
          <div class="blog-layout__featured">
            <BlogCard
              title={featured.data.title}
              description={featured.data.description}
              slug={featured.slug}
              pubDate={featured.data.pubDate}
              image={featured.data.image}
              category={featured.data.category}
              featured={true}
            />
          </div>
        )}
        <div class="blog-layout__side">
          {rest.map(post => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              slug={post.slug}
              pubDate={post.data.pubDate}
              image={post.data.image}
              category={post.data.category}
            />
          ))}
        </div>
      </div>
      <div class="blog-section__cta">
        <a href="/blog/" class="btn btn-outline">View All Guides</a>
      </div>
    </div>
  </section>
)}

<style>
.blog-section {
  padding: 80px 0;
  background: var(--green-xlt);
}
.blog-section__header {
  text-align: center;
  margin-bottom: 48px;
}
.blog-section__header .eyebrow { margin-bottom: 12px; display: block; }
.blog-section__header h2 { margin-bottom: 16px; }
.blog-section__header p { font-size: 15px; color: var(--text-muted); max-width: 520px; margin: 0 auto; }
.blog-layout {
  display: grid;
  grid-template-columns: 1.4fr 1fr;
  gap: 24px;
  margin-bottom: 40px;
}
.blog-layout__side { display: flex; flex-direction: column; gap: 16px; }
.blog-section__cta { text-align: center; }
@media (max-width: 768px) {
  .blog-layout { grid-template-columns: 1fr; }
}
</style>
