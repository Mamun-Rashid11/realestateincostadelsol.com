---
const navLinks = [
  { label: 'Costa del Sol', href: '/costa-del-sol/' },
  { label: 'Marbella', href: '/costa-del-sol/marbella/' },
  { label: 'Villas', href: '/villas-for-sale-costa-del-sol/' },
  { label: 'Apartments', href: '/apartments-costa-del-sol/' },
  { label: 'New Developments', href: '/new-developments-costa-del-sol/' },
  { label: 'Blog', href: '/blog/' },
];
---
<nav class="nav">
  <div class="container nav__inner">

    <!-- 1. Logo -->
    <a href="/" class="nav__logo">
      <span class="nav__logo-icon">R</span>
      <span class="nav__logo-text">Real Estate<br><em>Costa del Sol</em></span>
    </a>

    <!-- 2. Links (centre) -->
    <ul class="nav__links" id="navLinks">
      {navLinks.map(link => (
        <li><a href={link.href}>{link.label}</a></li>
      ))}
      <!-- mobile-only CTA inside dropdown -->
      <li class="nav__links-mobile-cta">
        <a href="/contact/" class="btn btn-accent">Free Enquiry</a>
      </li>
    </ul>

    <!-- 3. CTA (right) — desktop only -->
    <a href="/contact/" class="nav__cta btn btn-accent">Free Enquiry</a>

    <!-- hamburger — mobile only -->
    <button class="nav__hamburger" id="navToggle" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>

  </div>
</nav>

<style>
.nav {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--green);
  box-shadow: 0 2px 12px rgba(0,0,0,0.15);
}
.nav__inner {
  display: flex;
  align-items: center;
  height: 68px;
  gap: 16px;
}

/* 1 — Logo */
.nav__logo {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-shrink: 0;
  color: var(--white);
}
.nav__logo-icon {
  width: 36px;
  height: 36px;
  background: var(--accent);
  color: var(--green);
  font-family: 'Playfair Display', serif;
  font-weight: 700;
  font-size: 20px;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.nav__logo-text {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 13px;
  font-weight: 600;
  line-height: 1.3;
  color: var(--white);
}
.nav__logo-text em {
  font-style: normal;
  color: var(--accent);
  font-weight: 300;
}

/* 2 — Links (centre) */
.nav__links {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 2px;
  list-style: none;
}
.nav__links a {
  color: rgba(255,255,255,0.85);
  font-size: 13px;
  font-weight: 500;
  padding: 6px 10px;
  border-radius: 4px;
  transition: color 0.15s, background 0.15s;
  white-space: nowrap;
}
.nav__links a:hover { color: var(--white); background: rgba(255,255,255,0.08); }
.nav__links-mobile-cta { display: none; }

/* 3 — CTA button (right) */
.nav__cta {
  flex-shrink: 0;
}

/* Hamburger */
.nav__hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
  flex-shrink: 0;
}
.nav__hamburger span {
  display: block;
  width: 24px;
  height: 2px;
  background: var(--white);
  border-radius: 2px;
  transform-origin: center;
  transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
              opacity 0.2s ease;
}
/* Hamburger → X */
.nav__hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.nav__hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
.nav__hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* ── Mobile ── */
@media (max-width: 900px) {
  .nav__inner { justify-content: space-between; }
  .nav__hamburger { display: flex; }
  .nav__cta { display: none; }
  .nav__links-mobile-cta { display: block; }

  .nav__links {
    /* always flex in mobile — visibility controlled by max-height + opacity */
    display: flex;
    position: absolute;
    top: 68px;
    left: 0;
    right: 0;
    background: var(--green);
    flex-direction: column;
    align-items: stretch;
    gap: 2px;
    border-top: 1px solid rgba(255,255,255,0.1);
    overflow: hidden;

    /* closed state */
    max-height: 0;
    opacity: 0;
    padding: 0 20px;
    pointer-events: none;
    transition: max-height 0.35s cubic-bezier(0.22, 1, 0.36, 1),
                opacity 0.25s ease,
                padding 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  /* open state */
  .nav__links.open {
    max-height: 520px;
    opacity: 1;
    padding: 16px 20px 24px;
    pointer-events: auto;
  }
  .nav__links a { padding: 10px 12px; font-size: 15px; }
  .nav__links-mobile-cta a {
    display: block;
    text-align: center;
    margin-top: 8px;
    padding: 12px;
  }
}
</style>

<script>
const toggle = document.getElementById('navToggle');
const links  = document.getElementById('navLinks');
toggle?.addEventListener('click', () => {
  links?.classList.toggle('open');
  toggle.classList.toggle('open');
});
</script>
