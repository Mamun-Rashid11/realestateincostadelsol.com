---
import EnquiryFormCard from './EnquiryFormCard.astro';

interface Props {
  heading?: string;
  subheading?: string;
  area?: string;
}
const {
  heading = 'Find Your Perfect Property — Free',
  subheading = 'Tell us what you\'re looking for and we\'ll match you with the best options. No fees, no obligation.',
  area = '',
} = Astro.props;
---
<section class="lead-form-section">
  <div class="container">
    <div class="lead-form-wrap">

      <div class="lead-form__intro" data-animate>
        <span class="eyebrow">Free Property Enquiry</span>
        <h2>{heading}</h2>
        <p>{subheading}</p>
        <ul class="lead-form__benefits">
          <li>✓ No buyer fees — ever</li>
          <li>✓ UK-based support team</li>
          <li>✓ Access to 2,400+ properties</li>
          <li>✓ Post-Brexit buying guidance</li>
        </ul>
      </div>

      <div data-animate="fade-up" style="--anim-delay:120ms">
        <EnquiryFormCard area={area} prefix="lf" />
      </div>

    </div>
  </div>
</section>

<style>
.lead-form-section {
  padding: 80px 0;
  background: var(--green);
}
.lead-form-wrap {
  display: grid;
  grid-template-columns: 1fr 1.3fr;
  gap: 64px;
  align-items: start;
}
.lead-form__intro .eyebrow { color: var(--accent); margin-bottom: 16px; display: block; }
.lead-form__intro h2 {
  font-size: clamp(1.6rem, 3vw, 2.2rem);
  color: var(--white);
  margin-bottom: 16px;
}
.lead-form__intro p {
  font-size: 15px;
  color: rgba(255,255,255,0.75);
  line-height: 1.7;
  margin-bottom: 24px;
}
.lead-form__benefits {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.lead-form__benefits li {
  font-size: 14px;
  color: rgba(255,255,255,0.85);
}
@media (max-width: 900px) {
  .lead-form-wrap { grid-template-columns: 1fr; gap: 32px; }
}
</style>
