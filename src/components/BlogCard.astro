---
interface Props {
  title: string;
  description: string;
  slug: string;
  pubDate: Date;
  image?: string;
  category?: string;
  featured?: boolean;
}
const { title, description, slug, pubDate, image = 'https://images.unsplash.com/photo-1523531294919-4bcd7c65e216?w=800&q=75', category = 'Guide', featured = false } = Astro.props;
const dateStr = pubDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
---
<a href={`/blog/${slug}/`} class={`blog-card card-lift ${featured ? 'blog-card--featured' : ''}`} data-animate>
  <div class="blog-card__img-wrap">
    <img src={image} alt={title} loading="lazy" width={featured ? 800 : 400} height={featured ? 450 : 240} />
    <span class="blog-card__cat">{category}</span>
  </div>
  <div class="blog-card__body">
    <time class="blog-card__date">{dateStr}</time>
    <h3>{title}</h3>
    {featured && <p>{description}</p>}
    <span class="blog-card__read">Read guide →</span>
  </div>
</a>

<style>
.blog-card {
  display: block;
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid var(--border);
  background: var(--white);
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
  text-decoration: none;
}
.blog-card:hover {
  border-color: var(--green);
  box-shadow: 0 10px 32px rgba(27,58,45,0.13);
}
.blog-card__img-wrap {
  position: relative;
  overflow: hidden;
  background: var(--green-lt);
}
.blog-card--featured .blog-card__img-wrap { aspect-ratio: 16/9; }
.blog-card:not(.blog-card--featured) .blog-card__img-wrap { aspect-ratio: 5/3; }
.blog-card__img-wrap img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s; }
.blog-card:hover .blog-card__img-wrap img { transform: scale(1.04); }
.blog-card__cat {
  position: absolute;
  top: 12px;
  left: 12px;
  background: var(--accent);
  color: var(--white);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 4px 10px;
  border-radius: 4px;
}
.blog-card__body { padding: 20px; }
.blog-card__date {
  display: block;
  font-size: 12px;
  color: var(--text-light);
  margin-bottom: 8px;
}
.blog-card__body h3 {
  font-size: 18px;
  color: var(--text);
  margin-bottom: 10px;
  line-height: 1.3;
}
.blog-card--featured .blog-card__body h3 { font-size: 22px; }
.blog-card__body p {
  font-size: 14px;
  color: var(--text-muted);
  line-height: 1.6;
  margin-bottom: 14px;
}
.blog-card__read {
  font-size: 13px;
  font-weight: 600;
  color: var(--green);
}
</style>
