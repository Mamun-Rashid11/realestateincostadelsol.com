---
const types = [
  {
    label: 'Villas',
    href: '/villas-for-sale-costa-del-sol/',
    icon: '🏡',
    description: 'Luxury private villas with pools, gardens and sea views. From classic Andalusian to ultra-modern.',
    priceRange: '€250,000 – €5M+',
  },
  {
    label: 'Apartments',
    href: '/apartments-costa-del-sol/',
    icon: '🏢',
    description: 'Beach apartments, penthouses and city-centre flats. Ideal for holidays, rentals or retirement.',
    priceRange: '€65,000 – €800,000',
  },
  {
    label: 'New Developments',
    href: '/new-developments-costa-del-sol/',
    icon: '🏗️',
    description: 'Off-plan and newly built homes. Energy-efficient, modern specification, developer payment plans.',
    priceRange: '€120,000 – €2M+',
  },
];
---
<section class="types-section">
  <div class="container">
    <div class="types-section__header">
      <span class="eyebrow" data-animate>Property Types</span>
      <h2 class="section-h2" data-animate style="--anim-delay:80ms">What Are You Looking For?</h2>
    </div>
    <div class="types-grid" data-stagger data-stagger-base="80" data-stagger-step="100">
      {types.map(t => (
        <a href={t.href} class="type-card card-lift" data-animate>
          <div class="type-card__icon">{t.icon}</div>
          <h3>{t.label}</h3>
          <p>{t.description}</p>
          <span class="type-card__range">{t.priceRange}</span>
          <span class="type-card__link">Browse {t.label} →</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
.types-section {
  padding: 80px 0;
  background: var(--white);
}
.types-section__header {
  text-align: center;
  margin-bottom: 48px;
}
.types-section__header .eyebrow { margin-bottom: 12px; display: block; }
.types-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}
.type-card {
  display: flex;
  flex-direction: column;
  padding: 32px;
  border-radius: 12px;
  border: 1px solid var(--border);
  background: var(--green-lt);
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
  text-decoration: none;
  color: var(--text);
}
.type-card:hover {
  border-color: var(--green);
  box-shadow: 0 10px 32px rgba(27,58,45,0.13);
}
.type-card__icon {
  font-size: 36px;
  margin-bottom: 16px;
  width: 56px;
  height: 56px;
  background: var(--white);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.type-card h3 { font-size: 22px; margin-bottom: 10px; }
.type-card p { font-size: 14px; color: var(--text-muted); line-height: 1.6; flex: 1; margin-bottom: 16px; }
.type-card__range {
  font-size: 13px;
  font-weight: 600;
  color: var(--green-mid);
  margin-bottom: 12px;
}
.type-card__link {
  font-size: 13px;
  font-weight: 600;
  color: var(--green);
}
@media (max-width: 768px) {
  .types-grid { grid-template-columns: 1fr; }
}
</style>
