---
interface Props {
  heading?: string;
  subheading?: string;
  bgImage?: string;
}
const {
  heading = 'Find Your Dream Home on the Costa del Sol',
  subheading = 'Discover villas, apartments and new developments across Spain\'s most sought-after coastline. Trusted by UK and US buyers since 2020.',
  bgImage = 'https://images.unsplash.com/photo-1523531294919-4bcd7c65e216?w=1600&q=80',
} = Astro.props;
---
<section class="hero" style={`background-image: url('${bgImage}')`}>
  <div class="hero__overlay"></div>
  <div class="container hero__inner">

    <div class="hero__left">
      <span class="eyebrow hero__eyebrow" data-animate style="--anim-delay:100ms">Real Estate in Costa del Sol</span>
      <h1 class="hero__heading" data-animate style="--anim-delay:220ms">{heading}</h1>
      <p class="hero__sub" data-animate style="--anim-delay:340ms">{subheading}</p>
      <div class="hero__trust" data-animate style="--anim-delay:460ms">
        <span>✓ No agent fees</span>
        <span>✓ UK-based support</span>
        <span>✓ 2,400+ properties</span>
      </div>
    </div>

    <div class="hero__form-wrap" data-animate style="--anim-delay:300ms">
      <div class="hero__form-header">
        <strong>Free Property Enquiry</strong>
        <p>Tell us what you're looking for — we'll respond within 2 hours.</p>
      </div>
      <form
        class="hero__form"
        action="https://api.web3forms.com/submit"
        method="POST"
      >
        <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_KEY" />
        <input type="hidden" name="subject" value="New property enquiry — realestateincostadelsol.com" />
        <input type="hidden" name="redirect" value="https://realestateincostadelsol.com/thank-you/" />

        <div class="hero__form-row">
          <div class="hero__field">
            <label for="h-name">Full Name *</label>
            <input type="text" id="h-name" name="name" required placeholder="Your name" />
          </div>
          <div class="hero__field">
            <label for="h-email">Email *</label>
            <input type="email" id="h-email" name="email" required placeholder="your@email.com" />
          </div>
        </div>

        <div class="hero__form-row">
          <div class="hero__field">
            <label for="h-budget">Budget</label>
            <select id="h-budget" name="budget">
              <option value="">Select budget</option>
              <option>Up to €150,000</option>
              <option>€150,000 – €300,000</option>
              <option>€300,000 – €500,000</option>
              <option>€500,000+</option>
            </select>
          </div>
          <div class="hero__field">
            <label for="h-area">Area</label>
            <select id="h-area" name="area">
              <option value="">Any area</option>
              <option>Marbella</option>
              <option>Estepona</option>
              <option>Fuengirola</option>
              <option>Nerja</option>
              <option>Costa Blanca</option>
              <option>Open to suggestions</option>
            </select>
          </div>
        </div>

        <div class="hero__form-row">
          <div class="hero__field">
            <label for="h-type">Property Type</label>
            <select id="h-type" name="type">
              <option value="">Any type</option>
              <option>Villa</option>
              <option>Apartment</option>
              <option>New development</option>
              <option>Not sure</option>
            </select>
          </div>
          <div class="hero__field">
            <label for="h-beds">Bedrooms</label>
            <select id="h-beds" name="bedrooms">
              <option value="">Any</option>
              <option>1</option>
              <option>2</option>
              <option>3</option>
              <option>4+</option>
            </select>
          </div>
        </div>

        <button type="submit" class="btn btn-accent hero__submit">Send Free Enquiry</button>
        <p class="hero__form-note">No fees · No spam · Response within 2 hours</p>
      </form>
    </div>

  </div>
</section>

<style>
.hero {
  position: relative;
  min-height: 680px;
  display: flex;
  align-items: center;
  background-size: cover;
  background-position: center;
  background-color: var(--green);
}
.hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(27,58,45,0.9) 0%, rgba(27,58,45,0.72) 100%);
}
.hero__inner {
  position: relative;
  z-index: 1;
  padding-top: 80px;
  padding-bottom: 80px;
  display: grid;
  grid-template-columns: 1fr 420px;
  gap: 64px;
  align-items: center;
  width: 100%;
}
.hero__eyebrow { color: var(--accent); margin-bottom: 16px; display: block; }
.hero__heading {
  font-size: clamp(2rem, 4.5vw, 3.4rem);
  color: var(--white);
  margin-bottom: 20px;
  line-height: 1.15;
}
.hero__sub {
  font-size: 16px;
  color: rgba(255,255,255,0.82);
  margin-bottom: 32px;
  line-height: 1.7;
}
.hero__trust {
  display: flex;
  gap: 20px;
  flex-wrap: wrap;
  font-size: 13px;
  color: rgba(255,255,255,0.75);
}

/* Form card */
.hero__form-wrap {
  background: var(--white);
  border-radius: 16px;
  padding: 28px;
  box-shadow: 0 16px 48px rgba(0,0,0,0.25);
}
.hero__form-header {
  margin-bottom: 20px;
  padding-bottom: 16px;
  border-bottom: 1px solid var(--border);
}
.hero__form-header strong {
  display: block;
  font-family: 'Playfair Display', serif;
  font-size: 18px;
  color: var(--text);
  margin-bottom: 4px;
}
.hero__form-header p {
  font-size: 13px;
  color: var(--text-muted);
  margin: 0;
}
.hero__form {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.hero__form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}
.hero__field {
  display: flex;
  flex-direction: column;
  gap: 5px;
}
.hero__field label {
  font-size: 12px;
  font-weight: 600;
  color: var(--text);
}
.hero__field input,
.hero__field select {
  padding: 10px 12px;
  border: 1px solid var(--border);
  border-radius: 8px;
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 13px;
  color: var(--text);
  background: var(--off-white);
  transition: border-color 0.15s;
  width: 100%;
}
.hero__field input:focus,
.hero__field select:focus {
  outline: none;
  border-color: var(--green);
  background: var(--white);
}
.hero__submit {
  width: 100%;
  margin-top: 4px;
  font-size: 14px;
  padding: 14px;
}
.hero__form-note {
  font-size: 11px;
  color: var(--text-light);
  text-align: center;
  margin: 0;
}

@media (max-width: 960px) {
  .hero__inner {
    grid-template-columns: 1fr;
    gap: 40px;
    padding-top: 56px;
    padding-bottom: 56px;
  }
  .hero__form-wrap { max-width: 480px; }
}
@media (max-width: 560px) {
  .hero { min-height: auto; }
  .hero__form-row { grid-template-columns: 1fr; }
  .hero__form-wrap { padding: 20px; }
}

/* Hero elements animate on load (not scroll-triggered) */
.hero [data-animate] {
  animation: fadeUpBlur 0.75s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  animation-delay: var(--anim-delay, 0ms);
  opacity: 0;
}
@media (prefers-reduced-motion: reduce) {
  .hero [data-animate] { animation: none; opacity: 1; }
}
</style>
