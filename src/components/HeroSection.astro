---
interface Props {
  heading?: string;
  subheading?: string;
  bgImage?: string;
}
const {
  heading = 'Find Your Dream Home on the Costa del Sol',
  subheading = 'Discover villas, apartments and new developments across Spain\'s most sought-after coastline. Trusted by UK and US buyers since 2020.',
  bgImage = 'https://images.unsplash.com/photo-1523531294919-4bcd7c65e216?w=1600&q=80',
} = Astro.props;
---
<section class="hero" style={`background-image: url('${bgImage}')`}>
  <div class="hero__overlay"></div>
  <div class="container hero__inner">
    <span class="eyebrow hero__eyebrow" data-animate style="--anim-delay:100ms">Real Estate in Costa del Sol</span>
    <h1 class="hero__heading" data-animate style="--anim-delay:220ms">{heading}</h1>
    <p class="hero__sub" data-animate style="--anim-delay:340ms">{subheading}</p>
    <div class="hero__trust" data-animate style="--anim-delay:460ms">
      <span>✓ No agent fees</span>
      <span>✓ UK-based support</span>
      <span>✓ 2,400+ properties</span>
      <span>✓ Response within 2 hours</span>
    </div>
  </div>
</section>

<style>
.hero {
  position: relative;
  min-height: 520px;
  display: flex;
  align-items: center;
  background-size: cover;
  background-position: center;
  background-color: var(--green);
}
.hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(27,58,45,0.92) 0%, rgba(27,58,45,0.75) 100%);
}
.hero__inner {
  position: relative;
  z-index: 1;
  padding-top: 88px;
  padding-bottom: 88px;
  max-width: 760px;
}
.hero__eyebrow {
  color: var(--accent);
  margin-bottom: 16px;
  display: block;
}
.hero__heading {
  font-size: clamp(2.2rem, 5vw, 3.6rem);
  color: var(--white);
  margin-bottom: 20px;
  line-height: 1.15;
}
.hero__sub {
  font-size: 17px;
  color: rgba(255,255,255,0.82);
  margin-bottom: 36px;
  line-height: 1.75;
  max-width: 620px;
}
.hero__trust {
  display: flex;
  gap: 24px;
  flex-wrap: wrap;
  font-size: 13px;
  font-weight: 500;
  color: rgba(255,255,255,0.8);
}

/* Hero elements animate on load (not scroll-triggered) */
.hero [data-animate] {
  animation: fadeUpBlur 0.75s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  animation-delay: var(--anim-delay, 0ms);
  opacity: 0;
}
@media (prefers-reduced-motion: reduce) {
  .hero [data-animate] { animation: none; opacity: 1; }
}

@media (max-width: 768px) {
  .hero { min-height: auto; }
  .hero__inner { padding-top: 64px; padding-bottom: 64px; }
  .hero__heading { font-size: clamp(1.9rem, 6vw, 2.6rem); }
  .hero__trust { gap: 14px; }
}
</style>
