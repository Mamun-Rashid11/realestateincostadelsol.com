---
interface Props {
  name: string;
  href: string;
  description: string;
  priceFrom: string;
  image: string;
  featured?: boolean;
  properties?: number;
}
const { name, href, description, priceFrom, image, featured = false, properties = 120 } = Astro.props;
---
<a href={href} class={`area-card card-lift ${featured ? 'area-card--featured' : ''}`} data-animate>
  <div class="area-card__img-wrap">
    <img src={image} alt={`${name} property for sale`} loading="lazy" width="400" height="240" />
    {featured && <span class="area-card__badge">Most Popular</span>}
  </div>
  <div class="area-card__body">
    <h3>{name}</h3>
    <p>{description}</p>
    <div class="area-card__meta">
      <span class="area-card__price">From {priceFrom}</span>
      <span class="area-card__count">{properties} properties</span>
    </div>
  </div>
</a>

<style>
.area-card {
  display: block;
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid var(--border);
  background: var(--white);
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
  text-decoration: none;
}
.area-card:hover {
  border-color: var(--green);
  box-shadow: 0 10px 32px rgba(27,58,45,0.13);
}
.area-card--featured {
  background: var(--green);
  border-color: var(--green);
  color: var(--white);
}
.area-card__img-wrap {
  position: relative;
  aspect-ratio: 5/3;
  overflow: hidden;
  background: var(--green-lt);
}
.area-card__img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s;
}
.area-card:hover .area-card__img-wrap img { transform: scale(1.04); }
.area-card__badge {
  position: absolute;
  top: 12px;
  left: 12px;
  background: var(--accent);
  color: var(--white);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 4px 10px;
  border-radius: 4px;
}
.area-card__body { padding: 20px; }
.area-card__body h3 {
  font-size: 20px;
  margin-bottom: 6px;
  color: inherit;
}
.area-card--featured .area-card__body h3 { color: var(--white); }
.area-card__body p {
  font-size: 13px;
  color: var(--text-muted);
  margin-bottom: 14px;
  line-height: 1.5;
}
.area-card--featured .area-card__body p { color: rgba(255,255,255,0.75); }
.area-card__meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.area-card__price {
  font-size: 14px;
  font-weight: 600;
  color: var(--accent);
}
.area-card__count {
  font-size: 12px;
  color: var(--text-light);
}
.area-card--featured .area-card__count { color: rgba(255,255,255,0.5); }
</style>
